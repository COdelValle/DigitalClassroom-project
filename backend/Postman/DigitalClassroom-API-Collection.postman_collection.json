      "item": [
        {
          "name": "Students - Create New",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('student_id', jsonData.id);",
                  "    pm.test('Student created successfully', function() {",
                  "        pm.expect(jsonData.id).to.exist;",
                  "        pm.expect(jsonData.rut).to.exist;",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rut\": \"12.345.678-9\",\n  \"firstName\": \"Juan\",\n  \"middleName\": \"Carlos\",\n  \"lastName\": \"Pérez García\",\n  \"birthDate\": \"2010-05-15\",\n  \"allergies\": [\"Ninguna\"],\n  \"legalRepresentatives\": [\n    {\n      \"rut\": \"10.123.456-7\",\n      \"fullName\": \"María García\",\n      \"email\": \"maria@example.com\",\n      \"phoneNumber\": [\"+56 9 1111 2222\"],\n      \"relationship\": \"Madre\"\n    }\n  ]\n}"
            },
